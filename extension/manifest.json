{
  "manifest_version": 3,
  "name": "PersonaLabs Chill Mode",
  "description": "Local-only YouTube overlays that classify cards for Chill Mode using video titles.",
  "version": "0.1.0",
  "permissions": ["storage"],
  "host_permissions": ["https://www.youtube.com/*"],
  "action": {
    "default_title": "PersonaLabs Chill Mode",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "css": ["content.css"],
      "js": ["dictionaries.js", "scoring.js", "content.js"],
      "run_at": "document_idle"
    }
  ]
}
